KPI_APP_ENV=production
KPI_APP_DEBUG=0
KPI_APP_URL=https://kpi.example.com
KPI_DB_HOST=localhost
KPI_DB_PORT=3306
KPI_DB_NAME=kpi_app
KPI_DB_USER=kpi_user
KPI_DB_PASS=change-me
KPI_ADMIN_PIN_HASH="$2y$12$replace.with.a.real.password.hash"
KPI_LEADER_PIN_HASH="$2y$12$replace.with.a.real.password.hash"
KPI_WORK_DAYS=26
KPI_ALLOW_SCHEMA_MIGRATIONS=0
KPI_SESSION_IDLE_TIMEOUT=1800
KPI_SESSION_ABSOLUTE_TIMEOUT=28800
KPI_LOGIN_MAX_ATTEMPTS=5
KPI_LOGIN_WINDOW_SECONDS=900
KPI_LOGIN_LOCKOUT_SECONDS=900
KPI_MAX_REQUEST_BYTES=1048576
