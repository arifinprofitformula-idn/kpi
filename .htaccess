Options -Indexes

<Files ".env">
    Require all denied
</Files>

<FilesMatch "(^\.|^(README|DEPLOYMENT)\.md$|^package(-lock)?\.json$|^vite\.config\.js$|^eslint\.config\.js$|^(init_db|config|db)\.php$)">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^login/?$ login.php [L,QSA,NC]
    RewriteRule ^(?:api|database|frontend|scripts|src|tests)(?:/|$) - [F,L,NC]
    RewriteRule (^|/)\.git(?:/|$) - [F,L,NC]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
</IfModule>
